{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true
  },
  "compileOnSave": true,
  "include": [
    "src/functions.ts"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.tsx",
    "src/**/*.css"
  ]
}