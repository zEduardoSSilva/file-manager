rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // REGRAS MODIFICADAS PARA EXIGIR LOGIN
    match /docs_entregas/{docId} {
      allow read, write: if request.auth != null;
    }
    match /docs_funcionarios/{docId} {
      allow read, write: if request.auth != null;
    }
    match /docs_veiculos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /docs_faturamento/{docId} {
      allow read, write: if request.auth != null;
    }
    match /docs_mot_devolucao/{docId} {
      allow read, write: if request.auth != null;
    }
    match /pipeline_results/{docId=**} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      // Leitura: apenas o próprio usuário pode ler seu documento
      allow read: if request.auth != null && request.auth.uid == userId;

      // Atualização do próprio perfil: qualquer campo EXCETO role
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Criar/alterar role: somente usuários com role 'developer'
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer';
    }

    // REGRA NOVA ACRESCENTADA PARA CORRIGIR O ERRO
    match /motivos_devolucao/{docId} {
        allow read, write: if request.auth != null;
    }

    // SUAS REGRAS ORIGINAIS MANTIDAS
    match /usage/{usageDoc} {
      allow read: if true;
      allow write: if false;
    }

    match /_meta/{usageDoc} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}